{
  "$schema": "https://json-structure.org/draft/2020-12/schema",
  "name": "Object",
  "type": "object",
  "properties": {
    "Key": {
      "type": "string"
    },
    "LastModified": {
      "type": "string"
    },
    "ETag": {
      "type": "string"
    },
    "Size": {
